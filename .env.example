# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mestre_liu_artur"

# ─────────────────────────────────────────
# AUTH.JS (NextAuth v5)
# ─────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="sua-chave-secreta-aqui"
AUTH_URL="http://localhost:3000"

# OAuth opcional (Google)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ─────────────────────────────────────────
# PAGAMENTO (escolha um)
# ─────────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# MERCADOPAGO_ACCESS_TOKEN=""

# ─────────────────────────────────────────
# CLOUDINARY (upload de imagens)
# ─────────────────────────────────────────
# Encontre em: cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="seu_cloud_name"
NEXT_PUBLIC_CLOUDINARY_API_KEY="sua_api_key"   # chave pública, seguro expor
CLOUDINARY_API_SECRET="seu_api_secret"          # NUNCA exponha este valor
